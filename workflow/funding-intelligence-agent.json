    {
      "parameters": {
        "jsCode": "const parsed = JSON.parse($input.first().json.output);\n\nconst runDate = parsed.run_date ?? '';\nconst weeklySummary = parsed.weekly_summary ?? '';\nconst opportunities = parsed.opportunities ?? [];\n\nreturn opportunities.map((opp) => {\n  const deadline = opp.deadline ?? '';\n\n  let daysToDeadline = '';\n  if (deadline) {\n    const deadlineDate = new Date(deadline);\n    if (!isNaN(deadlineDate.getTime())) {\n      daysToDeadline = Math.ceil(\n        (deadlineDate - new Date()) / (1000 * 60 * 60 * 24)\n      );\n    }\n  }\n\n  let priorityBand = 'Low';\n  const relevance = Number(opp.relevance_score ?? 0);\n  if (relevance >= 8) {\n    priorityBand = 'High';\n  } else if (relevance >= 6) {\n    priorityBand = 'Medium';\n  }\n\n  return {\n    json: {\n      run_date: runDate,\n      weekly_summary: weeklySummary,\n      date_found: new Date().toISOString(),\n      week_start: new Date().toISOString().slice(0, 10),\n      organisation_name: opp.organisation_name ?? '',\n      opportunity_title: opp.opportunity_title ?? '',\n      opportunity_type: opp.opportunity_type ?? '',\n      for_entity: opp.for_entity ?? '',\n      country: opp.country ?? '',\n      funding_amount: opp.funding_amount ?? '',\n      currency: opp.currency ?? 'GBP',\n      deadline: opp.deadline ?? 'Not clearly stated',\n      eligibility: opp.eligibility ?? '',\n      why_relevant: opp.why_relevant ?? '',\n      application_link: opp.application_link ?? '',\n      contact_info: opp.contact_info ?? '',\n      status: 'New',\n      relevance_score: opp.relevance_score ?? '',\n      confidence_score: opp.confidence_score ?? '',\n      notes: opp.notes ?? 'Auto-added via research agent',\n      days_to_deadline: daysToDeadline,\n      priority_band: priorityBand,\n      source_url: opp.source_url ?? opp.application_link ?? ''\n    }\n  };\n});"
      },
