    {
      "parameters": {
        "jsCode": "const inputs = $input.all();\n\n// Separate incoming items by source node\nconst newItems = inputs.filter(item => item.pairedItem?.input === 0 || item.json.application_link);\nconst existingItems = inputs.filter(item => item.json['Application Link'] || item.json['Organisation Name']);\n\n// Build a set of existing application links from the sheet\nconst existingLinks = new Set(\n  existingItems\n    .map(item => item.json['Application Link'])\n    .filter(link => typeof link === 'string' && link.trim() !== '')\n);\n\n// Keep only opportunities whose application_link is not already in the sheet\nconst deduped = newItems.filter(item => {\n  const link = item.json.application_link;\n  return typeof link === 'string' && link.trim() !== '' && !existingLinks.has(link);\n});\n\nreturn deduped;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        736,
        32
      ],
      "id": "9c7a4933-8362-4e51-91ec-3efc5caba62c",
      "name": "DeDuplicate"
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\n// If no new opportunities were found this week\nif (!items.length) {\n  return [\n    {\n      json: {\n        subject: 'Weekly Funding Opportunities Report',\n        body: `Weekly Funding Opportunities Report\n\nRun date: ${new Date().toLocaleDateString('en-GB')}\n\nNo new opportunities were identified this week after deduplication.\n\nNext steps:\n- Keep the workflow running weekly\n- Review the existing tracker for open opportunities\n- Refine scoring criteria if needed`\n      }\n    }\n  ];\n}\n\n// Sort by relevance score descending\nconst sorted = [...items].sort((a, b) => {\n  return Number(b.json.relevance_score || 0) - Number(a.json.relevance_score || 0);\n});\n\n// Top opportunities overall\nconst top = sorted.slice(0, 5);\n\n// Top for Cultural Therapy\nconst culturalTherapy = sorted\n  .filter(item => (item.json.for_entity || '').toLowerCase().includes('cultural therapy'))\n  .slice(0, 3);\n\n// Top for investment company / seed funding side\nconst investment = sorted\n  .filter(item => {\n    const val = (item.json.for_entity || '').toLowerCase();\n    return val.includes('investment') || val.includes('both');\n  })\n  .slice(0, 3);\n\nfunction formatOpportunity(item, index) {\n  const j = item.json;\n  return `${index + 1}. ${j.opportunity_title}\nOrganisation: ${j.organisation_name}\nEntity: ${j.for_entity}\nCountry: ${j.country}\nFunding: ${j.funding_amount} ${j.currency || ''}\nDeadline: ${j.deadline}\nRelevance Score: ${j.relevance_score}\nWhy it matters: ${j.why_relevant}\nLink: ${j.application_link}\n`;\n}\n\nconst bodyParts = [];\n\nbodyParts.push(`Weekly Funding Opportunities Report\n\nRun date: ${new Date().toLocaleDateString('en-GB')}\n\nNew opportunities added this week: ${items.length}\n`);\n\nbodyParts.push(`Top 5 opportunities this week:\n${top.map(formatOpportunity).join('\\n')}`);\n\nif (culturalTherapy.length) {\n  bodyParts.push(`Top Cultural Therapy opportunities:\n${culturalTherapy.map(formatOpportunity).join('\\n')}`);\n}\n\nif (investment.length) {\n  bodyParts.push(`Top investment company opportunities:\n${investment.map(formatOpportunity).join('\\n')}`);\n}\n\nconst urgent = sorted.filter(item => {\n  const d = item.json.days_to_deadline;\n  return typeof d === 'number' && d >= 0 && d <= 14;\n});\n\nif (urgent.length) {\n  bodyParts.push(`Urgent deadlines in the next 14 days:\n${urgent.map(formatOpportunity).join('\\n')}`);\n}\n\nbodyParts.push(`Suggested next actions:\n- Review the top opportunities by relevance\n- Prioritise anything with a deadline within 14 days\n- Begin outreach or application prep for the strongest 2 to 3 options\n- Check the Google Sheet for full tracking details`);\n\nreturn [\n  {\n    json: {\n      subject: `Weekly Funding Opportunities Report - ${new Date().toLocaleDateString('en-GB')}`,\n      body: bodyParts.join('\\n\\n')\n    }\n  }\n];"
      },
